{
  "name": "calchowmuch",
  "version": "1.0.0",
  "description": "Fast, SEO-friendly calculator platform for math, finance, and health calculations",
  "type": "module",
  "scripts": {
    "build": "npm run build:css:route-bundles && node scripts/generate-mpa-pages.js --all",
    "build:css:route-bundles": "node scripts/sync-route-bundle-manifests.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --grep-invert \"UR-TEST-005/006\"",
    "test:cwv:all": "playwright test tests_specs/infrastructure/e2e/cls-guard-all-calculators.spec.js --workers=1",
    "test:cwv:target": "CLS_GUARD_ROUTE_INCLUDE=$TARGET playwright test tests_specs/infrastructure/e2e/cls-guard-all-calculators.spec.js --workers=1",
    "test:cwv:non-math": "CLS_GUARD_ROUTE_EXCLUDE=/math/ CLS_GUARD_REPORT_PATH=test-results/performance/cls-guard-non-math-calculators.json playwright test tests_specs/infrastructure/e2e/cls-guard-all-calculators.spec.js --workers=1",
    "test:cls:all": "playwright test tests_specs/infrastructure/e2e/cls-guard-all-calculators.spec.js --workers=1",
    "test:content:quality": "node scripts/content-quality-thin-score.mjs",
    "test:beacon:dedupe": "node scripts/beacon-duplicate-guard.mjs",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:above-fold": "playwright test tests_specs/infrastructure/e2e/above-the-fold-mutation.spec.js",
    "test:accessibility:ux": "playwright test tests_specs/infrastructure/e2e/accessibility-ux.spec.js",
    "test:iss": "playwright test tests_specs/infrastructure/e2e/iss",
    "test:iss001": "playwright test tests_specs/infrastructure/e2e/iss-design-001.spec.js",
    "test:cluster:unit": "node scripts/run-scoped-tests.mjs --level=cluster --type=unit",
    "test:cluster:e2e": "node scripts/run-scoped-tests.mjs --level=cluster --type=e2e",
    "test:cluster:seo": "node scripts/run-scoped-tests.mjs --level=cluster --type=seo",
    "test:cluster:cwv": "node scripts/run-scoped-tests.mjs --level=cluster --type=cwv",
    "test:cluster:playwright": "node scripts/run-scoped-tests.mjs --level=cluster --type=playwright-all",
    "test:calc:unit": "node scripts/run-scoped-tests.mjs --level=calc --type=unit",
    "test:calc:e2e": "node scripts/run-scoped-tests.mjs --level=calc --type=e2e",
    "test:calc:seo": "node scripts/run-scoped-tests.mjs --level=calc --type=seo",
    "test:calc:cwv": "node scripts/run-scoped-tests.mjs --level=calc --type=cwv",
    "test:calc:playwright": "node scripts/run-scoped-tests.mjs --level=calc --type=playwright-all",
    "test:calc:release": "npm run test:calc:unit && npm run test:calc:playwright && npm run test:homepage:search:contracts",
    "test:cluster:release": "npm run test:cluster:unit && npm run test:cluster:playwright && npm run test:cluster:contracts",
    "test:lighthouse:target": "node scripts/lighthouse-target.mjs",
    "ports:list": "node scripts/ports.mjs list",
    "ports:next-free": "node scripts/ports.mjs next-free",
    "ports:acquire": "node scripts/ports.mjs acquire",
    "ports:release": "node scripts/ports.mjs release",
    "ports:gc": "node scripts/ports.mjs gc",
    "test:lcp:loans": "node scripts/validate-lcp-budgets.mjs",
    "test:isolation:scope": "node scripts/validate-isolation-scope.mjs",
    "test:cluster:contracts": "node scripts/validate-cluster-contracts.mjs && npm run test:homepage:search:contracts",
    "test:homepage:search:contracts": "node scripts/validate-homepage-search-discoverability.mjs",
    "test:interaction:guard": "playwright test tests_specs/infrastructure/e2e/interaction-guard.spec.js",
    "test:mobile:ux": "playwright test tests_specs/infrastructure/e2e/mobile-ux.spec.js",
    "test:percentage:nav-guard": "node scripts/validate-percentage-nav-guard.mjs",
    "scope:route": "node scripts/validate-route-scope.mjs",
    "scope:route:planner": "node scripts/validate-route-scope.mjs --write-planner",
    "test:seo:source-finance": "vitest run tests_specs/finance/unit/finance-static-schema-source-parity.test.js",
    "test:lighthouse:fast": "LH_MODE=fast node scripts/lighthouse-target.mjs",
    "test:lighthouse:stable": "LH_MODE=stable node scripts/lighthouse-target.mjs",
    "test:lighthouse:full": "LH_MODE=full node scripts/lighthouse-target.mjs",
    "lint": "eslint public/assets/js --ext .js",
    "lint:css-import": "! grep -rn '@import' public/calculators/ --include='*.css' || (echo 'ERROR: @import found in calculator CSS files. Use shared-calculator-ui.css instead.' && exit 1)",
    "lint:fix": "eslint public/assets/js --ext .js --fix",
    "format": "prettier --write \"public/**/*.{js,html,css,json}\"",
    "format:check": "prettier --check \"public/**/*.{js,html,css,json}\"",
    "audit:local-seo": "node scripts/local-seo-performance-audit.mjs",
    "serve": "python -m http.server 8000 --directory public",
    "validate": "npm run lint && npm run lint:css-import && npm run test && npm run test:beacon:dedupe && npm run format:check"
  },
  "keywords": [
    "calculator",
    "math",
    "finance",
    "health",
    "static",
    "seo"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@vitest/coverage-v8": "^1.2.0",
    "eslint": "^8.56.0",
    "jsdom": "^23.2.0",
    "prettier": "^3.2.4",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
